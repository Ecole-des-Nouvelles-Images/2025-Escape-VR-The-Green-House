{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "8f46c11779ee47aebf8c4be726d92bfa",
    "m_Title": "Floating point precision",
    "m_Content": "Math, values and operations involved in the procedural checker/grid or behind the manipulation of the UVs are the best way to achieve sharp and accurate grid.\n\nThe nodes like \"Reciprocal\" are the also the more accurate way to ensure good floating point precision, which matter in the final render of the grid.",
    "m_TextSize": 1,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -6504.0,
        "y": -101.0,
        "width": 657.0,
        "height": 301.0
    },
    "m_Group": {
        "m_Id": "ecfe19418bbc411faa590ac954ffbf4a"
    }
}

