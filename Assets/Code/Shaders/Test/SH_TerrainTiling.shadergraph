{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "fbc4b91095404f588c86aa4898bbea0e",
    "m_Title": "Channel inversion",
    "m_Content": "There's an error in the explanations of Ben Cloward (Shader Graph Basics - Ep 47)\n\nWhere it would be obvious to connect RGB channel in the correct order (as per his sayings), it does generates hexagon artifacts in the Grid IDs.\n\nIt is necessary to invert Red and Blue channel (notice the twisting in the \"Split\" node) to somewhat get the good combination with the \"Swizzle\" nodes and restore correct grid masks.",
    "m_TextSize": 0,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3147.0,
        "y": 350.0,
        "width": 302.0,
        "height": 191.0
    },
    "m_Group": {
        "m_Id": "cbed906f89b2462696eef62a53ab1081"
    }
}

