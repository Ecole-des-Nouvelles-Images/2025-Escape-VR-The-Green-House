{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "055eceba3dc04b6eaf0ea0e64521e26a",
    "m_Title": "Channel IDs",
    "m_Content": "This shader is capable of handling 3 different UVs set of hexagonal grid tiles by splitting the RGB channels into 3 independent masks.\n\nThis enables up to 3 sets of individual random transformations, for example.\nEach of these transformation could be influenced differently thanks to these grids.",
    "m_TextSize": 1,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3776.0,
        "y": 587.0,
        "width": 546.0,
        "height": 311.0
    },
    "m_Group": {
        "m_Id": "cbed906f89b2462696eef62a53ab1081"
    }
}

{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "06502240a6a0460c89f6c4a4e8c1c3d0",
    "m_Title": "Floating point precision",
    "m_Content": "Math, values and operations involved in the procedural checker/grid or behind the manipulation of the UVs are the best way to achieve sharp and accurate grid.\n\nThe nodes like \"Reciprocal\" are the also the more accurate way to ensure good floating point precision, which matter in the final render of the grid.",
    "m_TextSize": 1,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -5526.0,
        "y": -254.0,
        "width": 657.0,
        "height": 301.0
    },
    "m_Group": {
        "m_Id": "24cef9c1826f43fa9833f4bd5f1996a9"
    }
}

